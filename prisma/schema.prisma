// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OFFICE
  AGENT
  PRIVATE_ADVERTISER
  SEEKER
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SOLD
  RENTED
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  OFFICE
  COMMERCIAL
  GARAGE
  OTHER
}

enum ListingType {
  SALE
  RENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CLOSED
}

enum ImageType {
  GALLERY
  COVER
  FLOOR_PLAN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  role          UserRole  @default(SEEKER)
  emailVerified DateTime?
  image         String?

  office        Office?
  agent         Agent?
  properties    Property[]    @relation("PropertyOwner")
  leads         Lead[]        @relation("LeadUser")
  favorites     Favorite[]
  inquiries     Inquiry[]
  savedSearches SavedSearch[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([deletedAt])
}

model Office {
  id          String  @id @default(cuid())
  userId      String  @unique
  name        String
  slug        String  @unique
  description String?
  email       String?
  phone       String?
  website     String?
  logoUrl     String?
  coverUrl    String?

  city      String?
  district  String?
  address   String?
  latitude  Float?
  longitude Float?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents     Agent[]
  properties Property[]
  leads      Lead[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([city])
  @@index([deletedAt])
}

model Agent {
  id        String  @id @default(cuid())
  userId    String  @unique
  officeId  String?
  name      String
  slug      String  @unique
  bio       String?
  phone     String?
  email     String?
  avatarUrl String?
  position  String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  office     Office?    @relation(fields: [officeId], references: [id], onDelete: SetNull)
  properties Property[]
  leads      Lead[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([officeId])
  @@index([deletedAt])
}

model Property {
  id       String  @id @default(cuid())
  ownerId  String
  officeId String?
  agentId  String?

  title        String
  slug         String         @unique
  description  String?
  status       PropertyStatus @default(DRAFT)
  propertyType PropertyType
  listingType  ListingType

  price       Int
  currency    String @default("HUF")
  areaM2      Int?
  rooms       Float?
  bedrooms    Int?
  bathrooms   Int?
  floor       Int?
  totalFloors Int?
  lotSizeM2   Int?
  builtYear   Int?

  city       String
  district   String?
  address    String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  isFeatured  Boolean   @default(false)
  publishedAt DateTime?

  owner     User              @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  office    Office?           @relation(fields: [officeId], references: [id], onDelete: SetNull)
  agent     Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  images    PropertyImage[]
  features  PropertyFeature[]
  leads     Lead[]
  favorites Favorite[]
  inquiries Inquiry[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([propertyType])
  @@index([listingType])
  @@index([city])
  @@index([district])
  @@index([price])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([ownerId])
  @@index([officeId])
  @@index([agentId])
  @@index([deletedAt])
}

model PropertyImage {
  id         String    @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  type       ImageType @default(GALLERY)
  sortOrder  Int       @default(0)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([type])
}

model PropertyFeature {
  id         String  @id @default(cuid())
  propertyId String
  key        String
  value      String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, key])
  @@index([propertyId])
}

model Lead {
  id         String  @id @default(cuid())
  propertyId String?
  officeId   String?
  agentId    String?
  userId     String?

  name    String
  email   String
  phone   String?
  message String
  status  LeadStatus @default(NEW)

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  office   Office?   @relation(fields: [officeId], references: [id], onDelete: SetNull)
  agent    Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  user     User?     @relation("LeadUser", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([propertyId])
  @@index([officeId])
  @@index([agentId])
  @@index([userId])
  @@index([deletedAt])
}

model Favorite {
  id         String @id @default(cuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Inquiry {
  id         String  @id @default(cuid())
  userId     String?
  propertyId String?

  name    String
  email   String
  phone   String?
  message String

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([propertyId])
  @@index([deletedAt])
}

model SavedSearch {
  id      String @id @default(cuid())
  userId  String
  name    String
  filters Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
